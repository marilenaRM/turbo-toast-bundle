{
    "name": "marilenarm/turbo-toast-bundle",
    "description": "Session-free flash/toast notifications for Symfony that keep your pages HTTP-cacheable, via Turbo Streams and a cookie transport.",
    "keywords": ["symfony", "bundle", "turbo", "stimulus", "toast", "flash", "notifications", "hotwire", "http-cache", "stateless"],
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Marilena Ruffelaere",
            "email": "marilena.ruffelaere@gmail.com",
            "homepage": "https://github.com/marilenaRM"
        }
    ],
    "require": {
        "php": ">=8.3",
        "psr/log": "^3.0",
        "symfony/config": "^7.0",
        "symfony/dependency-injection": "^7.0",
        "symfony/event-dispatcher": "^7.0",
        "symfony/http-foundation": "^7.0",
        "symfony/http-kernel": "^7.0",
        "symfony/service-contracts": "^3.5",
        "symfony/stimulus-bundle": "^2.13",
        "symfony/ux-turbo": "^2.13",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/twig-bundle": "^7.0",
        "vincentlanglet/twig-cs-fixer": "^4.0"
    },
    "scripts": {
        "test": "phpunit",
        "lint:twig": "twig-cs-fixer lint",
        "lint:twig:fix": "twig-cs-fixer lint --fix"
    },
    "autoload": {
        "psr-4": {
            "MarilenaRM\\TurboToastBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MarilenaRM\\TurboToastBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "funding": [
        {
            "type": "ko-fi",
            "url": "https://ko-fi.com/marilenarm"
        }
    ],
    "minimum-stability": "stable"
}
