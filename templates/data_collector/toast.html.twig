{% extends '@WebProfiler/Profiler/layout.html.twig' %}

{% block toolbar %}
    {% if collector.total > 0 %}
        {% set icon %}
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="3" y="7" width="18" height="10" rx="2" stroke="#AAA" stroke-width="2"/>
                <circle cx="7.5" cy="12" r="1.5" fill="#AAA"/>
                <path d="M11 10.5h7M11 13.5h5" stroke="#AAA" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span class="sf-toolbar-value">{{ collector.total }}</span>
        {% endset %}

        {% set text %}
            <div class="sf-toolbar-info-piece">
                <b>Turbo Stream toasts</b>
                <span class="sf-toolbar-status">{{ collector.streams|length }}</span>
            </div>
            <div class="sf-toolbar-info-piece">
                <b>Cookie-deferred toasts</b>
                <span class="sf-toolbar-status">{{ collector.deferred.pushed|length }}</span>
            </div>
            {% if collector.deferred.discarded > 0 %}
                <div class="sf-toolbar-info-piece">
                    <b>Discarded (server error)</b>
                    <span class="sf-toolbar-status sf-toolbar-status-red">{{ collector.deferred.discarded }}</span>
                </div>
            {% endif %}
        {% endset %}

        {{ include('@WebProfiler/Profiler/toolbar_item.html.twig', {link: profiler_url}) }}
    {% endif %}
{% endblock %}

{% block menu %}
    <span class="label {{ collector.total == 0 ? 'disabled' }}">
        <span class="icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="3" y="7" width="18" height="10" rx="2" stroke="currentColor" stroke-width="2"/>
                <circle cx="7.5" cy="12" r="1.5" fill="currentColor"/>
                <path d="M11 10.5h7M11 13.5h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
        </span>
        <strong>Turbo Toast</strong>
        {% if collector.total > 0 %}
            <span class="count">{{ collector.total }}</span>
        {% endif %}
    </span>
{% endblock %}

{% block panel %}
    <h2>Turbo Toast</h2>

    {% if collector.total == 0 %}
        <div class="empty">
            <p>No toast was emitted during this request.</p>
        </div>
    {% endif %}

    {% if collector.streams|length > 0 %}
        <h3>Rendered as Turbo Streams</h3>
        <table>
            <thead>
                <tr>
                    <th>Message</th>
                    <th>Type</th>
                    <th>Delay</th>
                </tr>
            </thead>
            <tbody>
                {% for toast in collector.streams %}
                    <tr>
                        <td>{{ toast.message }}</td>
                        <td><span class="label">{{ toast.type }}</span></td>
                        <td>{{ toast.delay ?? 'default' }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}

    {% if collector.deferred.pushed|length > 0 %}
        <h3>Deferred through the cookie</h3>
        <div class="metrics">
            <div class="metric">
                <span class="value">{{ collector.deferred.pushed|length }}</span>
                <span class="label">Queued</span>
            </div>
            <div class="metric">
                <span class="value">{{ collector.deferred.transported }}</span>
                <span class="label">Transported</span>
            </div>
            <div class="metric">
                <span class="value">{{ collector.deferred.discarded }}</span>
                <span class="label">Discarded (5xx)</span>
            </div>
        </div>
        <table>
            <thead>
                <tr>
                    <th>Message</th>
                    <th>Type</th>
                    <th>Delay</th>
                </tr>
            </thead>
            <tbody>
                {% for toast in collector.deferred.pushed %}
                    <tr>
                        <td>{{ toast.message }}</td>
                        <td><span class="label">{{ toast.type }}</span></td>
                        <td>{{ toast.delay ?? 'default' }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
